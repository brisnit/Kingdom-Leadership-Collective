# ============================================================================
# Kingdom Leadership Collective — environment
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Dashboard → Project Settings → API).
# ============================================================================

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / public API key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
